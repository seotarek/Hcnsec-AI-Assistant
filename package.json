{
  "name": "hcnsec-assistant",
  "displayName": "Hcnsec AI Assistant",
  "description": "Professional AI coding assistant powered by Hcnsec API — supports Arabic, English, Chinese | مساعد برمجي ذكي",
  "publisher": "antigravity",
  "version": "2.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "AI", "assistant", "chat", "arabic", "chinese", "deepseek", "hcnsec", "copilot", "agent"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hcnsec-container",
          "title": "Hcnsec AI",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "hcnsec-container": [
        {
          "type": "webview",
          "id": "hcnsec-chat-view",
          "name": "💬 Chat",
          "icon": "resources/icon.svg"
        },
        {
          "type": "webview",
          "id": "hcnsec-settings-view",
          "name": "⚙️ Settings",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "hcnsec.askAI",
        "title": "Hcnsec AI: Ask About This Code"
      },
      {
        "command": "hcnsec.sendFile",
        "title": "Hcnsec AI: Send Current File"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "hcnsec.askAI",
          "group": "1_modification"
        },
        {
          "command": "hcnsec.sendFile",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Hcnsec AI Assistant",
      "properties": {
        "hcnsec.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Hcnsec API Key (sk-...)"
        },
        "hcnsec.endpoint": {
          "type": "string",
          "default": "https://api.hcnsec.cn/v1/chat/completions",
          "description": "API Endpoint URL"
        },
        "hcnsec.model": {
          "type": "string",
          "default": "auto",
          "description": "Model to use for chat"
        },
        "hcnsec.language": {
          "type": "string",
          "default": "en",
          "enum": ["en", "ar", "zh"],
          "enumDescriptions": ["English", "العربية", "中文"],
          "description": "UI Language"
        },
        "hcnsec.agentMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable Agentic Mode (Planner + Executor)"
        },
        "hcnsec.plannerModel": {
          "type": "string",
          "default": "DeepSeek-V4-Pro",
          "description": "Model for planning steps in Agent Mode"
        },
        "hcnsec.executorModel": {
          "type": "string",
          "default": "DeepSeek-V4-Flash",
          "description": "Model for executing steps in Agent Mode"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
